{
  "title": "Cats vs Dogs \u2014 Model Inference Dashboard",
  "uid": "cats-dogs-monitor",
  "tags": [
    "mlops",
    "inference",
    "monitoring"
  ],
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Total Predictions",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(predictions_total)",
          "legendFormat": "Total Predictions"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{path='/predict'}[1m])",
          "legendFormat": "Predict req/s"
        }
      ]
    },
    {
      "id": 3,
      "title": "P95 Inference Latency (ms)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(prediction_latency_ms_bucket[5m]))",
          "legendFormat": "P95 Latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(prediction_errors_total[5m])",
          "legendFormat": "Errors/s"
        }
      ]
    },
    {
      "id": 5,
      "title": "Predictions by Class Over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "rate(predictions_total{label='cat'}[1m])",
          "legendFormat": "Cat predictions/s"
        },
        {
          "expr": "rate(predictions_total{label='dog'}[1m])",
          "legendFormat": "Dog predictions/s"
        }
      ]
    },
    {
      "id": 6,
      "title": "Inference Latency Distribution",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(prediction_latency_ms_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(prediction_latency_ms_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(prediction_latency_ms_bucket[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {}
}
